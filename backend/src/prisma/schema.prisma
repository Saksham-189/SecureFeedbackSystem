generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id         String   @id @default(uuid())
  name       String
  code       String   @unique
  email      String   @unique

  users      User[]
  forms      FeedbackForm[]

  createdAt  DateTime @default(now())
}

model Role {
  id      String @id @default(uuid())
  name    String @unique

  users   User[]
}

model User {

  id            String   @id @default(uuid())

  name          String
  email         String   @unique

  passwordHash  String

  department    String?
  year          Int?

  collegeId     String
  roleId        String

  college       College @relation(fields: [collegeId], references: [id])

  role          Role    @relation(fields: [roleId], references: [id])

  submissions   FeedbackSubmission[]

  createdAt     DateTime @default(now())
}

model FeedbackForm {

  id            String   @id @default(uuid())

  title         String
  description   String?

  collegeId     String

  college       College @relation(fields: [collegeId], references: [id])

  questions     Question[]

  submissions   FeedbackSubmission[]

  createdAt     DateTime @default(now())
}

model Question {

  id            String   @id @default(uuid())

  questionText  String

  questionType  String

  formId        String

  form          FeedbackForm
                @relation(fields: [formId], references: [id])

  responses     Response[]
}

model FeedbackSubmission {

  id               String   @id @default(uuid())

  formId           String

  studentId        String?

  anonymousToken   String   @unique

  form             FeedbackForm
                   @relation(fields: [formId], references: [id])

  student          User?
                   @relation(fields: [studentId], references: [id])

  responses        Response[]

  submittedAt      DateTime @default(now())
}

model Response {

  id               String   @id @default(uuid())

  submissionId     String

  questionId       String

  answerText       String

  submission       FeedbackSubmission
                   @relation(fields: [submissionId], references: [id])

  question         Question
                   @relation(fields: [questionId], references: [id])

  createdAt        DateTime @default(now())
}

model AuditLog {

  id            String   @id @default(uuid())

  userId        String?

  action        String

  resourceType  String?

  resourceId    String?

  ipAddress     String?

  severity      String

  timestamp     DateTime @default(now())
}