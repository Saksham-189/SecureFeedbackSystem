PORT=5000

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/secure_feedback"

# JWT Configuration
JWT_SECRET=generate_a_secure_random_string_here

# Field-Level Encryption Key (MUST BE EXACTLY 32 BYTES HEX)
# E.g., node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=your_32_byte_hex_string_here

# Environment
NODE_ENV=development

# Frontend URL (For CORS)
FRONTEND_URL=http://localhost:5173
